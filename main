<script>
let correctAnswers = 0;

function normalizeAnswer(str) {
  return str.trim().toLowerCase();
}

function checkAnswer(questionNumber, correctAnswer = null) {
  const input = document.getElementById('q' + questionNumber);
  const feedback = document.getElementById('feedback' + questionNumber);
  const question = input.closest('.question');
  
  if (questionNumber === 6) {
    const input1 = document.getElementById('q6a');
    const input2 = document.getElementById('q6b');
    const answer1 = normalizeAnswer(input1.value);
    const answer2 = normalizeAnswer(input2.value);
    
    const isCorrect = (answer1 === 'threw' && answer2 === 'away');
    
    feedback.classList.add('show');
    if (isCorrect) {
      feedback.textContent = '✓ Correto! "threw away" é o passado de "throw away"';
      feedback.classList.add('correct');
      feedback.classList.remove('incorrect');
      question.classList.add('correct');
      question.classList.remove('incorrect');
      if (!question.dataset.correct) {
        question.dataset.correct = true;
        updateProgress();
      }
    } else {
      feedback.textContent = '✗ Incorreto. Tente novamente! (Dica: threw away)';
      feedback.classList.add('incorrect');
      feedback.classList.remove('correct');
      question.classList.add('incorrect');
      question.classList.remove('correct');
    }
  } else {
    const userAnswer = normalizeAnswer(input.value);
    const isCorrect = userAnswer === normalizeAnswer(correctAnswer);
    
    feedback.classList.add('show');
    if (isCorrect) {
      feedback.textContent = '✓ Correto!';
      feedback.classList.add('correct');
      feedback.classList.remove('incorrect');
      question.classList.add('correct');
      question.classList.remove('incorrect');
      if (!question.dataset.correct) {
        question.dataset.correct = true;
        updateProgress();
      }
    } else {
      feedback.textContent = `✗ Incorreto. A resposta correta é: ${correctAnswer}`;
      feedback.classList.add('incorrect');
      feedback.classList.remove('correct');
      question.classList.add('incorrect');
      question.classList.remove('correct');
    }
  }
}

function updateProgress() {
  let count = 0;
  document.querySelectorAll('.question[data-correct="true"]').forEach(q => count++);
  correctAnswers = count;
  document.getElementById('correct-count').textContent = count;
  const progressPercent = (count / 6) * 100;
  document.getElementById('progress-fill').style.width = progressPercent + '%';
}

function showAllHints() {
  const hints = [
    'Q1: Algo feito sem intenção',
    'Q2: Pessoas que terminaram o casamento',
    'Q3: Lixo',
    'Q4: A forma como alguém age',
    'Q5: Comida que sobrou',
    'Q6: Passado de "throw" é "threw"'
  ];
  alert(hints.join('\n\n'));
}

function clearAll() {
  document.querySelectorAll('input[type="text"]').forEach(input => {
    input.value = '';
  });
  document.querySelectorAll('.feedback').forEach(feedback => {
    feedback.classList.remove('show');
  });
}

function resetExercise() {
  clearAll();
  document.querySelectorAll('.question').forEach(q => {
    q.classList.remove('correct', 'incorrect');
    q.dataset.correct = false;
  });
  correctAnswers = 0;
  updateProgress();
}

// Permitir Enter para submeter
document.querySelectorAll('input[type="text"]').forEach((input, index) => {
  input.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      const buttons = document.querySelectorAll('.check-btn');
      buttons[index].click();
    }
  });
});
</script>

</body>
